#!/bin/sh

# post-commit hook
# 在提交后自动生成并提交 changelog.json

# 防止递归：检查是否是由本钩子创建的提交
if [ "$SKIP_CHANGELOG_HOOK" = "1" ]; then
    exit 0
fi

# 检查最近一次提交是否已经是 changelog 更新
LAST_COMMIT_MSG=$(git log -1 --pretty=%B)
if echo "$LAST_COMMIT_MSG" | grep -q "\[auto\]"; then
    exit 0
fi

# 获取当前分支名
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "HEAD")

# 避免在 detached HEAD 状态下执行
if [ "$BRANCH" = "HEAD" ]; then
    exit 0
fi

# 生成 changelog
echo "[git-hook] 正在生成 changelog.json..."
node scripts/generate-changelog.js

# 检查是否有变更
if ! git diff --quiet public/changelog.json 2>/dev/null; then
    echo "[git-hook] 发现 changelog.json 变更，正在自动提交..."
    
    # 暂存 changelog.json
    git add public/changelog.json
    
    # 使用环境变量防止递归，并提交
    SKIP_CHANGELOG_HOOK=1 git commit --no-verify -m "chore: 更新 changelog.json [auto]"
    
    echo "[git-hook] changelog.json 已自动提交"
fi

exit 0
